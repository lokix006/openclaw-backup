#!/usr/bin/env python3
"""
Tweet Report Generator — Excel Only (v2)
- Sheet 1 "推文列表": 按 keyword/topic 分组，每组有标题行
- Sheet 2 "KOL分析": KOL 汇总，按原创帖数降序
- 时间戳：UTC+8（CST）
- Output: /tmp/openclaw/tweet-report-YYYYMMDD.xlsx
"""
import os, sys, json, requests, openpyxl, time, re
from datetime import datetime, timezone, timedelta
from openpyxl.styles import Font, PatternFill, Alignment
from openpyxl.utils import get_column_letter

ILLEGAL_CHARS_RE = re.compile(r'[\x00-\x08\x0b-\x0c\x0e-\x1f\x7f-\x9f]')
CST = timezone(timedelta(hours=8))

MAX_RETRIES = 20
RETRY_INTERVAL = 60

BLUE       = "4F81BD"
DARK_BLUE  = "1F3864"
LIGHT_GRAY = "F2F2F2"
ORANGE     = "F4B942"

def clean(val):
    if isinstance(val, str):
        return ILLEGAL_CHARS_RE.sub('', val)
    return val

def fmt_time(ts_ms: int) -> str:
    try:
        return datetime.fromtimestamp(ts_ms / 1000, tz=CST).strftime("%Y-%m-%d %H:%M")
    except Exception:
        return str(ts_ms)

def style_header_row(ws, row_num: int, bg: str = BLUE):
    for cell in ws[row_num]:
        cell.font = Font(bold=True, color="FFFFFF", size=11)
        cell.fill = PatternFill("solid", fgColor=bg)
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)

def style_topic_row(ws, row_num: int):
    for cell in ws[row_num]:
        cell.font = Font(bold=True, color="FFFFFF", size=11)
        cell.fill = PatternFill("solid", fgColor=DARK_BLUE)
        cell.alignment = Alignment(horizontal="left", vertical="center")

def style_data_row(ws, row_num: int, alternate: bool):
    bg = LIGHT_GRAY if alternate else "FFFFFF"
    for cell in ws[row_num]:
        cell.fill = PatternFill("solid", fgColor=bg)
        cell.alignment = Alignment(horizontal="left", vertical="center", wrap_text=False)

def auto_width(ws, max_width: int = 60):
    for i, col in enumerate(ws.columns, 1):
        w = max((len(str(c.value or "")) for c in col), default=10)
        ws.column_dimensions[get_column_letter(i)].width = min(w + 4, max_width)

# ── Load keywords ──────────────────────────────────────────────────────────────
_SCRIPT_DIR   = os.path.dirname(os.path.abspath(__file__))
_SKILL_DIR    = os.path.abspath(os.path.join(_SCRIPT_DIR, ".."))
KEYWORDS_FILE = os.path.join(_SKILL_DIR, "tweet_keywords.json")
try:
    with open(KEYWORDS_FILE) as f:
        KEYWORDS = json.load(f)
except Exception:
    KEYWORDS = ["openclaw", "clawbot"]

if not KEYWORDS:
    print("Error: keyword list is empty")
    sys.exit(1)

print(f"Keywords: {KEYWORDS}")

# ── Fetch data ─────────────────────────────────────────────────────────────────
API_URL = "https://knowledgebase.aichat.fun/api/v1/tweet/openclaw"
params = [("keywords", kw) for kw in KEYWORDS]

tweet_stats, kol_stats = None, None

for attempt in range(MAX_RETRIES):
    try:
        resp = requests.get(API_URL, params=params, timeout=300)
        resp.raise_for_status()
        raw_data = resp.json()["data"]

        if not isinstance(raw_data, dict):
            print("No tweet data returned for current keywords")
            sys.exit(1)

        if raw_data.get("computing"):
            print(f"[{datetime.now().strftime('%H:%M:%S')}] Computing... retry {attempt + 1}/{MAX_RETRIES} in {RETRY_INTERVAL // 60} min")
            time.sleep(RETRY_INTERVAL)
            continue

        tweet_stats = raw_data.get("tweet_stats") or []
        kol_stats   = raw_data.get("kol_stats") or []
        print(f"Fetched: {len(tweet_stats)} tweets, {len(kol_stats)} KOLs")
        break

    except Exception as e:
        print(f"Error on attempt {attempt + 1}: {e}")
        time.sleep(RETRY_INTERVAL)
else:
    print("❌ 推文数据同步超时（等待超过20分钟），请稍后重试。")
    sys.exit(1)

# ── Group tweets by keyword ────────────────────────────────────────────────────
# Each tweet may match multiple keywords; we assign by keyword order (first match wins)
# The API returns all tweets together, so we try to group by kol_handle / url match
# Since API doesn't return keyword-per-tweet, we fetch per keyword separately
# But current API takes all keywords at once — so we use a best-effort grouping
# by dividing into KEYWORD groups based on tweet order (API may return grouped)
# If we can't determine topic, put into first keyword bucket

# Re-fetch per keyword to get proper grouping
keyword_tweets: dict[str, list] = {kw: [] for kw in KEYWORDS}

for kw in KEYWORDS:
    for attempt in range(5):
        try:
            r = requests.get(API_URL, params=[("keywords", kw)], timeout=120)
            r.raise_for_status()
            d = r.json().get("data", {})
            if d.get("computing"):
                time.sleep(30)
                continue
            keyword_tweets[kw] = d.get("tweet_stats") or []
            print(f"  [{kw}] {len(keyword_tweets[kw])} tweets")
            break
        except Exception as e:
            print(f"  [{kw}] retry {attempt+1}: {e}")
            time.sleep(15)

# ── Build Excel ────────────────────────────────────────────────────────────────
wb = openpyxl.Workbook()

# ── Sheet 1: 推文列表（按 topic 分组）─────────────────────────────────────────
ws1 = wb.active
ws1.title = "推文列表"
ws1.row_dimensions[1].height = 30

TWEET_COLS = ["KOL Handle", "KOL 昵称", "推文链接", "时间（CST）", "转发数", "点赞数", "评论数"]
ws1.append(TWEET_COLS)
style_header_row(ws1, 1, BLUE)

date_range_label = f"数据时间：{datetime.now(tz=CST).strftime('%Y-%m-%d %H:%M CST')} 生成"

row_idx = 2
for kw in KEYWORDS:
    tweets = keyword_tweets.get(kw, [])
    tweets_sorted = sorted(tweets, key=lambda x: x.get("like_count", 0), reverse=True)

    # Topic title row
    ws1.cell(row=row_idx, column=1, value=f"🔖 {kw}  ({len(tweets_sorted)} tweets)")
    ws1.merge_cells(start_row=row_idx, start_column=1, end_row=row_idx, end_column=len(TWEET_COLS))
    style_topic_row(ws1, row_idx)
    ws1.row_dimensions[row_idx].height = 22
    row_idx += 1

    if not tweets_sorted:
        ws1.cell(row=row_idx, column=1, value="（暂无数据）")
        ws1.merge_cells(start_row=row_idx, start_column=1, end_row=row_idx, end_column=len(TWEET_COLS))
        ws1.row_dimensions[row_idx].height = 18
        row_idx += 1
        continue

    for i, t in enumerate(tweets_sorted):
        ts = fmt_time(t.get("tweet_created_at", 0))
        ws1.append([
            clean(t.get("kol_handle", "")),
            clean(t.get("kol_nickname", "")),
            clean(t.get("tweet_url", "")),
            ts,
            t.get("retweet_count", 0),
            t.get("like_count", 0),
            t.get("reply_count", 0),
        ])
        style_data_row(ws1, row_idx, alternate=(i % 2 == 1))
        ws1.row_dimensions[row_idx].height = 18
        row_idx += 1

# Set column widths manually for readability
col_widths = [18, 18, 55, 18, 8, 8, 8]
for i, w in enumerate(col_widths, 1):
    ws1.column_dimensions[get_column_letter(i)].width = w

# Freeze header row
ws1.freeze_panes = "A2"

# ── Sheet 2: KOL分析 ───────────────────────────────────────────────────────────
ws2 = wb.create_sheet("KOL分析")
KOL_COLS = ["KOL Handle", "KOL 昵称", "原创AI帖数"]
ws2.append(KOL_COLS)
style_header_row(ws2, 1, ORANGE)
ws2.row_dimensions[1].height = 28

kol_stats_sorted = sorted(kol_stats, key=lambda x: x.get("original_ai_post", 0), reverse=True)
for i, k in enumerate(kol_stats_sorted):
    ws2.append([
        clean(k.get("kol_handle", "")),
        clean(k.get("kol_nickname", "")),
        k.get("original_ai_post", 0),
    ])
    style_data_row(ws2, i + 2, alternate=(i % 2 == 1))
    ws2.row_dimensions[i + 2].height = 18

kol_col_widths = [20, 20, 14]
for i, w in enumerate(kol_col_widths, 1):
    ws2.column_dimensions[get_column_letter(i)].width = w

ws2.freeze_panes = "A2"

# ── Save ───────────────────────────────────────────────────────────────────────
date_str = datetime.now(tz=CST).strftime("%Y%m%d")
_out_dir = "/tmp/openclaw"
os.makedirs(_out_dir, exist_ok=True)
xlsx_path = f"{_out_dir}/tweet-report-{date_str}.xlsx"
wb.save(xlsx_path)

total_tweets = sum(len(v) for v in keyword_tweets.values())
print(f"Excel saved: {xlsx_path} ({total_tweets} tweets across {len(KEYWORDS)} topics, {len(kol_stats_sorted)} KOLs)")
